PORT=5000
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxx.mongodb.net/chrome_gst_db
JWT_SECRET=<min-32-char-random-string>
ENCRYPTION_KEY=<64-char-hex-string-32-bytes>
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<your-strong-password>
DEVICE_SECRET=<random-string-shared-with-extension>
TOTP_SECRET=<run: node scripts/generate-totp-secret.js>
TOTP_SETUP_DISABLED=false
